<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Movie Recommender</title>

<style>
body {
    margin: 0;
    font-family: Arial;
    background: #020617;
    color: white;
    overflow-x: hidden;
}

/* Falling background */
.bg {
    position: fixed;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: -1;
}

.bg span {
    position: absolute;
    display: block;
    width: 40px;
    height: 60px;
    background: rgba(255,255,255,0.05);
    animation: fall linear infinite;
}

@keyframes fall {
    0% { transform: translateY(-100px); }
    100% { transform: translateY(100vh); }
}

.header {
    text-align: center;
    padding: 20px;
    font-size: 32px;
    font-weight: bold;
    letter-spacing: 2px;
}

.search-box {
    display: flex;
    justify-content: center;
    margin-bottom: 20px;
}

input {
    padding: 12px;
    width: 300px;
    border-radius: 5px;
    border: none;
}

button {
    padding: 12px;
    margin-left: 10px;
    background: #22c55e;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    color: white;
}

.movies {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 20px;
    padding: 20px;
}

.card {
    background: #0f172a;
    border-radius: 10px;
    overflow: hidden;
    transition: transform 0.3s;
}

.card:hover {
    transform: scale(1.08);
}

.card img {
    width: 100%;
    height: 250px;
    object-fit: cover;
}

.title {
    padding: 10px;
    text-align: center;
    font-size: 14px;
}
</style>
</head>

<body>

<div class="bg" id="bg"></div>

<div class="header">🎬 Movie Recommender</div>

<div class="search-box">
    <input id="search" placeholder="Search movie...">
    <button onclick="searchMovie()">Search</button>
</div>

<div class="movies" id="movies"></div>

<script>
const API_KEY = "1752279";

/* Background animation */
for (let i = 0; i < 30; i++) {
    let span = document.createElement("span");
    span.style.left = Math.random() * 100 + "%";
    span.style.animationDuration = (3 + Math.random() * 5) + "s";
    span.style.opacity = Math.random();
    document.getElementById("bg").appendChild(span);
}

/* Movie search */
async function searchMovie() {
    const query = document.getElementById("search").value.trim();
    if (!query) return;

    const res = await fetch(`https://www.omdbapi.com/?apikey=${API_KEY}&s=${encodeURIComponent(query)}`);
    const data = await res.json();

    const container = document.getElementById("movies");
    container.innerHTML = "";

    if (data.Response === "True") {
        data.Search.forEach(movie => {
            container.innerHTML += `
                <div class="card">
                    <img src="${movie.Poster !== 'N/A' ? movie.Poster : 'https://via.placeholder.com/300'}">
                    <div class="title">${movie.Title}</div>
                </div>
            `;
        });
    } else {
        container.innerHTML = "<p style='text-align:center'>No results found</p>";
    }
}
</script>

</body>
</html>
